# ============================================================
# ESG Manager — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env or any real secrets to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Required. PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/esgmanager

# ── Session / Auth ────────────────────────────────────────────
# Required. Must be at least 32 characters of random data.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-minimum-32-char-random-secret

# ── Environment ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Application Base URL ──────────────────────────────────────
# Required in production for email links, OAuth callbacks, and billing redirects.
APP_BASE_URL=https://your-app.replit.app

# ── AI / OpenAI ───────────────────────────────────────────────
# Required for AI assistant and ESG advisor features.
# Provided via Replit AI Integrations — do not paste raw keys here in production.
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# Fallback key (optional — AI Integrations key takes precedence)
OPENAI_API_KEY=sk-...

# ── Email (Resend) ────────────────────────────────────────────
# Required for password reset, invitations, and report-ready notifications.
# Leave unset to disable email (app logs a warning and skips email sends).
RESEND_API_KEY=re_...
EMAIL_FROM=ESG Manager <noreply@yourdomain.com>

# ── Payments (Stripe) ─────────────────────────────────────────
# Required for Pro plan billing. Leave unset to disable billing UI.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ── Replit Hosting ────────────────────────────────────────────
# Set automatically by Replit. Used for CORS allow-list.
REPLIT_DOMAINS=your-app.replit.app

# ── Agent / Webhook Integration (optional) ───────────────────
# URL where the external AI Agent Service receives critical health event webhooks.
AGENT_WEBHOOK_URL=
# Base URL of the external AI Agent Service for chat message forwarding.
AGENT_SERVICE_URL=
